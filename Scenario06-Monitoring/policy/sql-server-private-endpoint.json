{
  "properties": {
    "displayName": "Enforce Private Endpoint and disable public access for Azure SQL Server",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Requires Azure SQL Servers to have public network access disabled and to use private endpoints.",
    "metadata": {
      "version": "1.0.0",
      "category": "SQL"
    },
    "parameters": {},
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Sql/servers"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Sql/servers/publicNetworkAccess",
                "notEquals": "Disabled"
              },
              {
                "count": {
                  "field": "Microsoft.Sql/servers/privateEndpointConnections[*]"
                },
                "equals": 0
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "deny"
      }
    }
  }
}
